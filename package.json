{
  "name": "wmstudio-cli",
  "version": "0.2.7",
  "description": "Command-line client for the WM Studio creative platform. Generates images, videos, brand campaigns, and 3D assets from your terminal.",
  "type": "module",
  "bin": {
    "wm": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "prepublishOnly": "pnpm check && pnpm build",
    "release": "changeset publish"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "ora": "^8.1.0",
    "undici": "^6.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.7.0",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.12.0",
    "msw": "^2.4.9",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.2"
  },
  "keywords": [
    "wmstudio",
    "cli",
    "ai",
    "image-generation",
    "video-generation",
    "fal-ai",
    "creative-tools"
  ],
  "homepage": "https://wmstudio.io/docs/cli",
  "bugs": {
    "url": "https://wmstudio.io/support"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
